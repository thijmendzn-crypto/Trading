# === API KEYS ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# === DATABASE ===
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/trading_platform

# === REDIS ===
REDIS_URL=redis://localhost:6379/0

# === EXCHANGE (Binance - public endpoints, no key needed for market data) ===
BINANCE_API_KEY=optional_for_live_trading
BINANCE_SECRET_KEY=optional_for_live_trading

# === TRADING CONFIG ===
PORTFOLIO_VALUE=10000
MAX_RISK_PER_TRADE=0.01
MAX_DAILY_RISK=0.03
MIN_SIGNAL_SCORE=70
MIN_CONFIDENCE=0.65
MIN_RR=2.5

# === ASSETS TO MONITOR ===
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# === ENVIRONMENT ===
ENVIRONMENT=development
LOG_LEVEL=INFO
